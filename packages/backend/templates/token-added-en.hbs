<!DOCTYPE html>
<html>

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tokens Added</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');

    body {
      margin: 0;
      padding: 0;
      width: 100% !important;
      font-family: 'Inter', Helvetica, Arial, sans-serif;
      background-color: #f5f5f5;
      color: #111827;
      -webkit-font-smoothing: antialiased;
    }

    .wrapper {
      width: 100%;
      table-layout: fixed;
      background-color: #f5f5f5;
      padding-bottom: 40px;
    }

    .container {
      max-width: 600px;
      background-color: #ffffff;
      margin: 0 auto;
      border: 1px solid #e5e7eb;
    }

    @media screen and (max-width: 600px) {
      .content {
        padding: 32px 24px !important;
      }

      .header {
        padding: 24px !important;
      }

      .footer {
        padding: 24px !important;
      }

      h1 {
        font-size: 22px !important;
      }

      .token-amount {
        font-size: 36px !important;
      }
    }
  </style>
</head>

<body style="margin:0; padding:0; background-color:#f5f5f5;">

  <table class="wrapper" border="0" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td align="center" style="padding-top: 48px; padding-bottom: 48px;">

        <table class="container" border="0" cellpadding="0" cellspacing="0" width="100%"
          style="max-width: 600px; background-color: #ffffff; border: 1px solid #e5e7eb; border-spacing: 0;">

          <!-- Header -->
          <tr>
            <td class="header" style="padding: 40px 48px 32px; border-bottom: 1px solid #e5e7eb;">
              <table border="0" cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td>
                    <span
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 18px; font-weight: 600; color: #111827; letter-spacing: -0.5px; text-transform: uppercase;">
                      TreinaVaga<span style="color: #7f00ff;">AI</span>
                    </span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td class="content" style="padding: 48px;">
              <h1
                style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 24px; font-weight: 600; color: #111827; margin: 0 0 24px; letter-spacing: -0.5px; line-height: 1.3;">
                Tokens Added
              </h1>

              <p
                style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 15px; line-height: 1.6; color: #374151; margin: 0 0 32px;">
                Hi {{name}}, we have good news for you. An administrator has added new tokens to your account to
                boost your learning.
              </p>

              <!-- Token Details Card -->
              <table border="0" cellpadding="0" cellspacing="0" width="100%"
                style="margin-bottom: 32px; border: 1px solid #e5e7eb; background-color: #ffffff;">
                <tr>
                  <td align="center" style="padding: 32px 24px;">
                    <span
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 11px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 1px;">
                      Amount Added
                    </span>
                    <div class="token-amount"
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 48px; font-weight: 600; color: #111827; margin: 16px 0; letter-spacing: -1px;">
                      +{{amount}}
                    </div>

                    <table border="0" cellpadding="0" cellspacing="0" width="100%">
                      <tr>
                        <td align="center" style="padding-top: 8px;">
                          <span
                            style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 14px; color: #4b5563;">
                            New Balance: <strong style="color: #111827; font-weight: 600;">{{newBalance}} tokens</strong>
                          </span>
                        </td>
                      </tr>
                      {{#if reason}}
                      <tr>
                        <td align="center" style="padding-top: 16px; padding-bottom: 0;">
                          <p
                            style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 13px; color: #6b7280; background-color: #f9fafb; display: inline-block; padding: 6px 12px; margin: 0; border-radius: 4px;">
                            Reason: {{reason}}
                          </p>
                        </td>
                      </tr>
                      {{/if}}
                    </table>

                  </td>
                </tr>
              </table>

              <p
                style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 15px; line-height: 1.6; color: #374151; margin: 0 0 32px;">
                Use your tokens to take new interview simulations, access exclusive quizzes, and unlock
                premium features on the platform.
              </p>

              <!-- Primary Button -->
              <table border="0" cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td align="left">
                    <a href="{{appUrl}}"
                      style="display: inline-block; padding: 14px 36px; background-color: #111827; color: #ffffff; text-decoration: none; font-family: 'Inter', Helvetica, Arial, sans-serif; font-weight: 500; font-size: 14px; border: 1px solid #111827; letter-spacing: 0.2px;">
                      Access Platform &rarr;
                    </a>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td class="footer" style="padding: 32px 48px; background-color: #f9fafb; border-top: 1px solid #e5e7eb;">
              <table border="0" cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td style="padding-bottom: 16px;">
                    <p
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 13px; color: #374151; font-weight: 500; margin: 0;">
                      TreinaVagaAI
                    </p>
                  </td>
                  <td align="right" style="padding-bottom: 16px;">
                    <a href="#"
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 12px; color: #6b7280; text-decoration: none; margin-left: 16px;">Support</a>
                  </td>
                </tr>
                <tr>
                  <td colspan="2" style="border-top: 1px solid #e5e7eb; padding-top: 16px;">
                    <p
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 11px; color: #9ca3af; line-height: 1.5; margin: 0;">
                      &copy; {{year}} TreinaVagaAI. All rights reserved.<br>
                      This is an automated email, please do not reply.
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>

      </td>
    </tr>
  </table>

</body>

</html>
