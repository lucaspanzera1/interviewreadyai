<!DOCTYPE html>
<html>

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bem-vindo ao TreinaVagaAI!</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');

    body {
      margin: 0;
      padding: 0;
      width: 100% !important;
      font-family: 'Inter', Helvetica, Arial, sans-serif;
      background-color: #f5f5f5;
      color: #111827;
      -webkit-font-smoothing: antialiased;
    }

    .wrapper {
      width: 100%;
      table-layout: fixed;
      background-color: #f5f5f5;
      padding-bottom: 40px;
    }

    .container {
      max-width: 600px;
      background-color: #ffffff;
      margin: 0 auto;
      border: 1px solid #e5e7eb;
    }

    /* Mobile Responsive */
    @media screen and (max-width: 600px) {
      .content {
        padding: 32px 24px !important;
      }

      .header {
        padding: 24px !important;
      }

      .footer {
        padding: 24px !important;
      }

      h1 {
        font-size: 22px !important;
      }
    }
  </style>
</head>

<body style="margin:0; padding:0; background-color:#f5f5f5;">

  <table class="wrapper" border="0" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td align="center" style="padding-top: 48px; padding-bottom: 48px;">

        <!-- Main Container -->
        <table class="container" border="0" cellpadding="0" cellspacing="0" width="100%"
          style="max-width: 600px; background-color: #ffffff; border: 1px solid #e5e7eb; border-spacing: 0;">

          <!-- Header -->
          <tr>
            <td class="header" style="padding: 40px 48px 32px; border-bottom: 1px solid #e5e7eb;">
              <table border="0" cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td>
                    <!-- Minimalist Logo Text -->
                    <span
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 18px; font-weight: 600; color: #111827; letter-spacing: -0.5px; text-transform: uppercase;">
                      TreinaVaga<span style="color: #7f00ff;">AI</span>
                    </span>
                  </td>
                  <td align="right">
                    <!-- Date or decorative element can go here -->
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td class="content" style="padding: 48px;">
              <h1
                style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 24px; font-weight: 600; color: #111827; margin: 0 0 24px; letter-spacing: -0.5px; line-height: 1.3;">
                Bem-vindo(a), {{name}}
              </h1>

              <p
                style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 15px; line-height: 1.6; color: #374151; margin: 0 0 24px;">
                Você acaba de dar um passo importante para a sua carreira. No TreinaVagaAI, conectamos você às melhores
                ferramentas de preparação com inteligência artificial.
              </p>

              <!-- Welcome Bonus Banner -->
              <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 32px;">
                <tr>
                  <td style="background-color: #f5f0ff; border-left: 3px solid #7f00ff; padding: 16px 20px;">
                    <span
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #7f00ff; display: block; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px;">
                      🎁 Bônus de Boas-vindas
                    </span>
                    <span
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 14px; color: #374151; line-height: 1.5;">
                      Sua conta foi creditada com <strong>5 tokens gratuitos</strong> para você começar a praticar agora mesmo!
                    </span>
                  </td>
                </tr>
              </table>

              <!-- Fine Line Divider with Label -->
              <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 24px;">
                <tr>
                  <td style="border-bottom: 1px solid #e5e7eb; padding-bottom: 8px;">
                    <span
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 11px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 1px;">
                      Primeiros Passos
                    </span>
                  </td>
                </tr>
              </table>

              <!-- Action Items List (Clean, bordered) -->
              <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 40px;">
                <tr>
                  <td style="padding: 16px 0; border-bottom: 1px solid #f3f4f6;">
                    <span
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 14px; color: #111827; font-weight: 500;">01.
                      Pratique</span>
                    <br>
                    <span
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 13px; color: #6b7280; display: block; margin-top: 4px;">Realize
                      simulados de entrevista com nossa IA avançada.</span>
                  </td>
                </tr>
                <tr>
                  <td style="padding: 16px 0; border-bottom: 1px solid #f3f4f6;">
                    <span
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 14px; color: #111827; font-weight: 500;">02.
                      Analise</span>
                    <br>
                    <span
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 13px; color: #6b7280; display: block; margin-top: 4px;">Receba
                      feedback detalhado sobre sua performance e pontos de melhoria.</span>
                  </td>
                </tr>
                <tr>
                  <td style="padding: 16px 0;">
                    <span
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 14px; color: #111827; font-weight: 500;">03.
                      Evolua</span>
                    <br>
                    <span
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 13px; color: #6b7280; display: block; margin-top: 4px;">Acompanhe
                      seu progresso e conquiste sua vaga dos sonhos.</span>
                  </td>
                </tr>
              </table>

              <!-- Primary Button (Sharp corners) -->
              <table border="0" cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td align="left">
                    <a href="{{appUrl}}"
                      style="display: inline-block; padding: 14px 36px; background-color: #111827; color: #ffffff; text-decoration: none; font-family: 'Inter', Helvetica, Arial, sans-serif; font-weight: 500; font-size: 14px; border: 1px solid #111827; letter-spacing: 0.2px;">
                      Começar Agora &rarr;
                    </a>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td class="footer" style="padding: 32px 48px; background-color: #f9fafb; border-top: 1px solid #e5e7eb;">
              <table border="0" cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td style="padding-bottom: 16px;">
                    <p
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 13px; color: #374151; font-weight: 500; margin: 0;">
                      TreinaVagaAI
                    </p>
                  </td>
                  <td align="right" style="padding-bottom: 16px;">
                    <!-- Social icons could go here, keeping it text for now -->
                    <a href="#"
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 12px; color: #6b7280; text-decoration: none; margin-left: 16px;">Suporte</a>
                    <a href="#"
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 12px; color: #6b7280; text-decoration: none; margin-left: 16px;">Privacidade</a>
                  </td>
                </tr>
                <tr>
                  <td colspan="2" style="border-top: 1px solid #e5e7eb; padding-top: 16px;">
                    <p
                      style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 11px; color: #9ca3af; line-height: 1.5; margin: 0;">
                      &copy; {{year}} TreinaVagaAI. Todos os direitos reservados.<br>
                      Este é um email automático, por favor não responda.
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>

      </td>
    </tr>
  </table>
</body>

</html>